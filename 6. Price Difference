WITH CTE1 AS (select t2.department,
max(t1.salary) max_salary
from db_employee t1
LEFT JOIN db_dept t2
    ON t1.department_id = t2.id
WHERE department in ('engineering', 'marketing')
GROUP BY 1)
SELECT ABS(SUM(CASE WHEN department = 'engineering' THEN max_salary END)-
    SUM(CASE WHEN department = 'marketing' THEN max_salary END)) AS salary_difference
FROM CTE1
;

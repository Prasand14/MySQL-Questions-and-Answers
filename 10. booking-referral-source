WITH CTE1 AS (SELECT t1.user_id, 
  t1.booking_id, 
  t1.booking_date,
  COALESCE(t2.channel, 'Unattributed') as channel
FROM bookings t1
LEFT JOIN booking_attribution t2
  ON t1.booking_id = t2.booking_id),
CTE2 AS (SELECT *,
  ROW_NUMBER() OVER (PARTITION BY user_id ORDER BY booking_date asc) as rnk
FROM CTE1),
CTE3 AS (SELECT channel, COUNT(*) as booking_count
	FROM CTE2
	WHERE rnk = 1
	GROUP BY 1)
SELECT channel, 
  (booking_count*100.0)/SUM(booking_count) OVER () AS first_booking_pct
FROM CTE3
ORDER BY 2 DESC
LIMIT 1
;
